{
  "apiVersion": "skills.ooder.io/v1",
  "kind": "ProfileConfig",
  "metadata": {
    "name": "micro",
    "description": "微型部署，适合开发测试"
  },
  "spec": {
    "resources": {
      "cpu": "2",
      "memory": "4Gi"
    },
    "capabilities": {
      "llm": {
        "enabled": true,
        "default": "skill-llm-ollama",
        "config": {
          "model": "llama3"
        }
      },
      "db": {
        "enabled": true,
        "default": "skill-db-mysql",
        "config": {
          "pool": {
            "maxActive": 5
          }
        }
      },
      "vfs": {
        "enabled": true,
        "default": "skill-vfs-local"
      },
      "know": {
        "enabled": false
      }
    }
  }
}
