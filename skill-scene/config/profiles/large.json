{
  "apiVersion": "skills.ooder.io/v1",
  "kind": "ProfileConfig",
  "metadata": {
    "name": "large",
    "description": "大型部署，适合企业生产"
  },
  "spec": {
    "resources": {
      "cpu": "8",
      "memory": "16Gi"
    },
    "capabilities": {
      "llm": {
        "enabled": true,
        "default": "skill-llm-deepseek",
        "fallback": "skill-llm-openai",
        "config": {
          "model": "deepseek-chat",
          "pool": {
            "maxConnections": 10
          }
        }
      },
      "db": {
        "enabled": true,
        "default": "skill-db-postgres",
        "config": {
          "pool": {
            "maxActive": 30
          }
        }
      },
      "vfs": {
        "enabled": true,
        "default": "skill-vfs-s3"
      },
      "know": {
        "enabled": true,
        "default": "skill-know-rag",
        "config": {
          "vector": {
            "enabled": true,
            "backend": "milvus"
          }
        }
      }
    }
  }
}
