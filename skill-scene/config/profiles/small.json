{
  "apiVersion": "skills.ooder.io/v1",
  "kind": "ProfileConfig",
  "metadata": {
    "name": "small",
    "description": "小型部署，适合小团队"
  },
  "spec": {
    "resources": {
      "cpu": "4",
      "memory": "8Gi"
    },
    "capabilities": {
      "llm": {
        "enabled": true,
        "default": "skill-llm-deepseek",
        "config": {
          "model": "deepseek-chat"
        }
      },
      "db": {
        "enabled": true,
        "default": "skill-db-mysql",
        "config": {
          "pool": {
            "maxActive": 10
          }
        }
      },
      "vfs": {
        "enabled": true,
        "default": "skill-vfs-local"
      },
      "know": {
        "enabled": true,
        "default": "skill-know-rag",
        "config": {
          "topK": 5
        }
      }
    }
  }
}
