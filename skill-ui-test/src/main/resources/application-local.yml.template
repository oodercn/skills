# Local Development Configuration
# Copy this file to application-local.yml and fill in your API keys
# This file is ignored by git

server:
  port: 8080

spring:
  application:
    name: skill-ui-test

ooder:
  llm:
    provider: baidu
    api-key: YOUR_BAIDU_API_KEY_HERE
    base-url: https://qianfan.baidubce.com/v2
    model: ernie-4.0-8k
    embedding-model: embedding-v1

deepseek:
  api-key: YOUR_DEEPSEEK_API_KEY_HERE
  base-url: https://api.deepseek.com
  model: deepseek-chat
  timeout: 60000

logging:
  level:
    net.ooder: DEBUG
